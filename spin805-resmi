        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-left: 3px solid var(--color);
        padding-left: 8px;
      }

      .seo-footer p {
        font-size: 11px;
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.6;
        margin-bottom: 12px;
        text-align: justify;
      }

      .footer-links {
