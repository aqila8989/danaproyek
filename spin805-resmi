    <style amp-custom>
      * { 
        box-sizing: border-box; 
        margin: 0;
        padding: 0;
      }
      
      :root {
        --color: #6900ff;
        --color-light: #76df9b;
        --color-dark: #6900ff;
        --black: #000000;
        --dark: #76df9b;
        --gradient-color: linear-gradient(135deg, #6900ff, #6900ff, #6900ff);
        --shadow-color: 0 0 20px var(--color);
        --shadow-glow: 0 0 30px var(--color-light);
      }
      
      body { 
        font-family: 'Courier New', monospace; 
        background: #000000;
        background-image: 
          radial-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 1px),
          radial-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px);
        background-size: 40px 40px, 80px 80px;
        background-position: 0 0, 20px 20px;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
      }
      
      body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: 
          radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.08), transparent 40%),
          radial-gradient(circle at 80% 70%, rgba(255, 215, 0, 0.1), transparent 50%);
        pointer-events: none;
        z-index: -1;
        animation: pulseBg 8s ease-in-out infinite;
      }
      
      @keyframes pulseBg {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
      }
      
      .container { 
        max-width: 420px; 
        width: 90%;
        margin: 20px auto; 
        padding: 25px 20px; 
        display: flex; 
        flex-direction: column; 
        gap: 15px;
        background: rgba(10, 8, 2, 0.85);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 30px;
        box-shadow: 
          0 0 0 1px rgba(255, 255, 255, 0.1),
          0 20px 40px rgba(0, 0, 0, 0.8),
          inset 0 0 30px rgba(255, 255, 255, 0.1);
        position: relative;
        overflow: hidden;
        animation: fadeInUp 0.8s ease;
      }
      
      .container::before {
        content: '';
        position: absolute;
        top: -2px;
        left: -2px;
        right: -2px;
        bottom: -2px;
        background: conic-gradient(
          from 0deg,
          transparent,
          var(--color),
          var(--color-light),
          var(--color),
          transparent
        );
        border-radius: 32px;
        z-index: -2;
        animation: rotateBorder 6s linear infinite;
      }
      
      .container::after {
        content: '';
        position: absolute;
        inset: 2px;
        background: rgba(22, 5, 41, 0.95);
        border-radius: 28px;
        z-index: -1;
      }
      
      @keyframes rotateBorder {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
      }
      
      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      
      .welcome { 
        margin: 0 auto 5px; 
        width: 100%;
      }
      
      .welcome h3 { 
        font-size: 14px; 
        color: var(--color-light); 
        white-space: nowrap; 
        letter-spacing: 2px; 
        text-transform: uppercase;
        font-weight: 700;
        text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
        margin: 0 auto;
        display: inline-block;
      }
      
      .banner { 
        border-radius: 20px; 
        box-shadow: 
          0 10px 20px rgba(0, 0, 0, 0.5),
          0 0 0 2px rgba(255, 255, 255, 0.3),
          inset 0 0 20px rgba(255, 255, 255, 0.2);
        transition: all 0.3s ease;
      }
      
      .banner:hover {
        transform: scale(1.02);
        box-shadow: 
          0 15px 30px rgba(0, 0, 0, 0.6),
          0 0 0 3px rgba(255, 255, 255, 0.5),
          inset 0 0 30px rgba(255, 255, 255, 0.3);
      }
      
      .btn-login, .btn-daftar { 
        padding: 16px; 
        font-size: 18px; 
        font-weight: 800; 
        text-decoration: none; 
        text-align: center; 
        margin: 5px 0;
        border-radius: 50px;
        position: relative;
        z-index: 1;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 2px;
        border: none;
        cursor: pointer;
      }
      
      .btn-login {
        background: linear-gradient(145deg, #6900ff, #76df9b);
        color: #ffffff;
        border: 1px solid var(--color);
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.7);
      }
      
      .btn-daftar {
        background: linear-gradient(145deg, #6900ff, #76df9b);
        color: #ffffff;
        font-weight: 900;
        border: 1px solid var(--color-light);
        box-shadow: 0 5px 20px rgba(255, 255, 255, 0.4);
      }
      
      .btn-login:hover, .btn-daftar:hover {
        transform: translateY(-3px);
        filter: brightness(1.2);
      }
      
      .btn-login:hover {
        box-shadow: 0 8px 25px rgba(255, 255, 255, 0.3);
      }
      
      .btn-daftar:hover {
        box-shadow: 0 8px 30px rgba(255, 254, 247, 0.6);
      }
      
      .glow-on-hover {
        position: relative;
        overflow: hidden;
      }
      
      .glow-on-hover::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -60%;
        width: 200%;
        height: 200%;
        background: linear-gradient(
          to right,
          transparent,
          rgba(255, 255, 255, 0.1),
          transparent
        );
        transform: rotate(30deg);
        transition: transform 0.6s ease;
        pointer-events: none;
      }
      
      .glow-on-hover:hover::after {
        transform: rotate(30deg) translate(20%, 20%);
      }
      
      .button-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 10px;
        margin-top: 10px;
      }
      
      .button-grid a {
        padding: 12px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        text-align: center;
